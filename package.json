{
  "author": "Skiftle",
  "description": "The typed fetch client",
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@skiftle/biome-config": "0.0.7",
    "lefthook": "2.1.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "api",
    "client",
    "typed",
    "typescript",
    "zod",
    "contract"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "name": "sorbus",
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skiftle/sorbus.git"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "0.0.9"
}
